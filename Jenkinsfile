pipeline{
    agent any 
 stages{
     stage('SCM Checkout'){
         steps{  echo 'Hello we started the SCM-Checkout Process'}
          steps{git 'https://github.com/Prajwalatkare1/maven-project.git'}
          steps{echo 'Hello we Ended the SCM_Checkout Process  '} 
     }
     
      stage('Test '){
         steps{echo "cancel"}
          steps{echo "cancel"}
          steps{echo "cancel"} 
     }
     
      stage('Deploy'){
         steps{echo "cancel"}
          steps{echo "cancel"}
          steps{echo "cancel"} 
     }
 }
}
